# Local/server runtime example
MONGO_URI=mongodb://127.0.0.1:27017/expo
LOCAL_FALLBACK_MONGO_URI=mongodb://127.0.0.1:27017/expo
ALLOW_INMEMORY_FALLBACK=false
SHADOW_DB_NAME=expo_shadow
ENABLE_BACKUP_SCHEDULER=true

PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:5000
# Optional browser URL used in email deep links (gate pass/open-app links)
# PUBLIC_APP_URL=http://localhost:3000
# CLIENT_URL=http://localhost:3000

SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
COOKIE_SECRET=replace_with_secure_random_value
EMAIL_CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars_or_base64_32_bytes
EMERGENCY_RESET_SECRET=replace_with_secure_random_value
ENABLE_CSRF=true
TRUST_PROXY_HOPS=1
MAX_BACKUP_UPLOAD_MB=1024
SEED_DEFAULTS=false

# Optional SMTP (can also be managed from app settings)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password
# FROM_NAME=Expo Stores
