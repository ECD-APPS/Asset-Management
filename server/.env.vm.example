# App VM production example for your VLAN design
# App VM: 10.96.133.197
# DB VM: 10.96.133.213

MONGO_URI=mongodb://user:pass@10.96.133.213:27017/expo-stores
LOCAL_FALLBACK_MONGO_URI=mongodb://user:pass@10.96.133.213:27017/expo-stores
ALLOW_INMEMORY_FALLBACK=false
SHADOW_DB_NAME=expo_shadow
ENABLE_BACKUP_SCHEDULER=true
PORT=5000
NODE_ENV=production
SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
COOKIE_SECRET=replace_with_secure_random_value
EMAIL_CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars_or_base64_32_bytes
EMERGENCY_RESET_SECRET=replace_with_secure_random_value
ENABLE_CSRF=true
TRUST_PROXY_HOPS=1
MAX_BACKUP_UPLOAD_MB=1024
# Auth mode: HTTP-only cookies only (JWT is not used)
# Percona Backup for MongoDB — set on the app host that runs backup jobs
# PBM_MONGODB_URI=mongodb://pbmUser:pbmPass@10.96.133.213:27017/?authSource=admin
# PBM_BACKUP_WAIT_TIME=4h
# If Web VM serves HTTP use:
CORS_ORIGIN=http://10.96.133.181
# If Web VM serves HTTPS (TLS termination), switch to:
# CORS_ORIGIN=https://10.96.133.181
# API public base (used for some server-generated links)
PUBLIC_BASE_URL=http://10.96.133.197:5000
# Optional: same as browser URL of the SPA for email deep links (gate pass flow)
# PUBLIC_APP_URL=http://10.96.133.181
# CLIENT_URL=http://10.96.133.181
SEED_DEFAULTS=false

# When SEED_DEFAULTS=true, startup ensures these default accounts exist:
# - superadmin@expo.com => superadmin123
# - scy@expo.com => admin123
# - it@expo.com => admin123
# - noc@expo.com => admin123

# Optional email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
FROM_NAME=Expo Stores
